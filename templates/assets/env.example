# .env.example — PES standard
#
# Copy to `.env` (gitignored) and fill in real values. Every variable the
# project reads locally MUST be listed here with a fake value and a comment.
# CI equivalents live in GitHub Actions secrets / Xcode Cloud env vars.
#
# Rules:
# - .env is NEVER committed (enforced by .gitignore).
# - Keep this file in sync when adding/removing variables — it is the docs.

# --- Firebase (delete if unused) ---
# Service account JSON path for local admin scripts (dev project only)
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-dev-sa.json

# --- App Store Connect (delete if unused) ---
APP_STORE_CONNECT_KEY_ID=ABC123XYZ
APP_STORE_CONNECT_ISSUER_ID=00000000-0000-0000-0000-000000000000
APP_STORE_CONNECT_KEY_PATH=./secrets/AuthKey_ABC123XYZ.p8

# --- Project-specific ---
# EXAMPLE_API_BASE_URL=https://api.example.com

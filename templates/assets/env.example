# .env.example — PES standard
#
# Local fallback only — CI owns all of these via GitHub secrets
# (ASC_KEY_ID / ASC_ISSUER_ID / ASC_KEY_CONTENT / FIREBASE_SERVICE_ACCOUNT)
# and Xcode Cloud manages signing. For local fastlane runs, copy to
# `fastlane/.env` (gitignored; fastlane auto-loads it from there).
#
# Rules:
# - .env is NEVER committed (enforced by .gitignore).
# - Keep this file in sync when adding/removing variables — it is the docs.
# - Variable names must match what the Fastfile actually reads (ASC_*).

# --- App Store Connect API key (preferred auth; see Fastfile setup_api_key) ---
ASC_KEY_ID=ABC123XYZ
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
# Contents of the .p8 key file
ASC_KEY_CONTENT=-----BEGIN PRIVATE KEY-----...

# --- Apple ID fallback (interactive auth only; review_notes lane email) ---
FASTLANE_APPLE_ID=you@example.com

# --- Firebase (delete if the app has no data hosting) ---
# Service account JSON path for local deploys — CI uses the
# FIREBASE_SERVICE_ACCOUNT secret instead.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-sa.json

# --- Project-specific (delete section if empty) ---
# EXAMPLE_API_BASE_URL=https://api.example.com
